{
  "context": "..",
  "remoteUser": "root",
  "forwardPorts": [
    3000,
    5173
  ],
  "features": {
      "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
        "terminal.integrated.env.linux": {
          "CI": "true"
        }
      }
    }
  },
  "postStartCommand": "npm run start:frontend",
  "name": "tic-proyecto Dev Container",
  "dockerFile": "Dockerfile"
}
